{
  "name": "requestpilot",
  "version": "1.1.0",
  "type": "module",
  "description": "Microsoft Edge extension for modifying HTTP requests and responses",
  "scripts": {
    "build": "tsc && node scripts/copy-assets.cjs",
    "watch": "tsc --watch",
    "dev": "tsc && node scripts/copy-assets.cjs",
    "test": "node --test tests/*.test.mjs",
    "check": "npm run build && npm test",
    "package": "npm run check && node scripts/package-release.cjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "typescript": "^5.4.5"
  },
  "keywords": [
    "browser-extension",
    "http",
    "headers",
    "edge",
    "chrome"
  ],
  "license": "MIT"
}
